{
  "name": "@lionad/leader-line",
  "version": "1.0.0",
  "title": "LeaderLine",
  "description": "Draw a leader line in your web page.",
  "keywords": [
    "leader",
    "line",
    "markup",
    "arrow",
    "attention",
    "highlight",
    "spotlight",
    "bubble",
    "svg"
  ],
  "main": "./dist/leader-line.cjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/leader-line.mjs",
      "require": "./dist/leader-line.cjs",
      "default": "./dist/leader-line.mjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitest/browser-playwright": "^4.1.10",
    "cheerio": "^1.2.0",
    "clean-css": "^5.1.2",
    "eslint": "^9.39.5",
    "htmlclean": "^3.0.8",
    "playwright": "^1.61.1",
    "pre-proc": "^1.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "test": "vitest run",
    "test:smoke": "node test/smoke/dist-smoke.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "test:bench": "node test/perf/run-bench.mjs",
    "typecheck": "tsgo --noEmit -p tsconfig.json && cd playground && node node_modules/nuxt/bin/nuxt.mjs typecheck",
    "lint": "eslint .",
    "dev:playground": "cd playground && node node_modules/nuxt/bin/nuxt.mjs dev --host 0.0.0.0 --port $(npx -y @lionad/port-key playground)"
  },
  "homepage": "https://github.com/Lionad-Morotar/leader-line#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:Lionad-Morotar/leader-line.git"
  },
  "license": "MIT",
  "author": {
    "name": "Lionad-Morotar",
    "url": "https://github.com/Lionad-Morotar"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "fsevents",
      "@parcel/watcher"
    ]
  },
  "module": "./dist/leader-line.mjs",
  "types": "./index.d.ts",
  "sideEffects": true,
  "dependencies": {
    "anim-event": "^1.0.17",
    "cssprefix": "^2.0.17",
    "m-class-list": "^1.1.10",
    "pointer-event": "^1.3.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
