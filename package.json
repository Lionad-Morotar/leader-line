{
  "name": "leader-line",
  "version": "1.1.0",
  "title": "LeaderLine",
  "description": "Draw a leader line in your web page.",
  "keywords": [
    "leader",
    "line",
    "markup",
    "arrow",
    "attention",
    "highlight",
    "spotlight",
    "bubble",
    "svg"
  ],
  "main": "./dist/leader-line.cjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/leader-line.mjs",
      "require": "./dist/leader-line.cjs",
      "default": "./dist/leader-line.mjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitest/browser-playwright": "^4.1.10",
    "anim-event": "^1.0.16",
    "cheerio": "^1.2.0",
    "clean-css": "^5.1.2",
    "htmlclean": "^3.0.8",
    "jasmine-core": "^3.7.1",
    "log4js": "^6.4.0",
    "node-static-alias": "^1.1.2",
    "plain-draggable": "^2.5.12",
    "playwright": "^1.61.1",
    "pre-proc": "^1.0.2",
    "test-page-loader": "^1.0.8",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "test": "vitest run",
    "test:smoke": "node test/smoke/dist-smoke.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "test:bench": "node test/perf/run-bench.mjs",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "homepage": "https://github.com/Lionad-Morotar/leader-line",
  "repository": {
    "type": "git",
    "url": "git@github.com:Lionad-Morotar/leader-line.git"
  },
  "license": "MIT",
  "author": {
    "name": "Lionad-Morotar",
    "url": "https://github.com/Lionad-Morotar"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "fsevents"
    ]
  },
  "module": "./dist/leader-line.mjs",
  "types": "./index.d.ts",
  "sideEffects": false
}
