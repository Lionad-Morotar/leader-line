{
  "name": "@lionad/leader-line-nuxt",
  "version": "0.1.0",
  "description": "Nuxt module for @lionad/leader-line-vue — auto-imports, client-only plugin, global defaults.",
  "keywords": [
    "leader-line",
    "nuxt",
    "nuxt-module",
    "vue"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@lionad/leader-line-vue": "workspace:*",
    "@nuxt/kit": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "nuxt": "^4.1.3",
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "Lionad-Morotar",
    "url": "https://github.com/Lionad-Morotar"
  },
  "homepage": "https://github.com/Lionad-Morotar/leader-line#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:Lionad-Morotar/leader-line.git",
    "directory": "packages/nuxt"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
